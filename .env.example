# ========== Upstash Redis ==========
# 通过 Vercel Marketplace 连接 Upstash Redis 集成会自动注入以下变量
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ========== Vercel Blob ==========
# 通过 Vercel Dashboard Storage → Blob 创建并连接到项目后自动注入
BLOB_READ_WRITE_TOKEN=

# ========== 单用户白名单 ==========
# 仅允许此手机号登录；格式为 11 位中国大陆手机号（1[3-9]XXXXXXXXX）
ALLOWED_PHONE=

# ========== 定时清理鉴权 ==========
# Vercel Cron 调用 /api/cron/cleanup-blobs 时校验 Authorization: Bearer $CRON_SECRET
# 推荐生成方式：openssl rand -hex 32 | tr -d '\n'
CRON_SECRET=
